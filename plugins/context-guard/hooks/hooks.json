{
  "description": "Allay context-guard: drift detection and token estimation after every tool call",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use/detect-drift.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
